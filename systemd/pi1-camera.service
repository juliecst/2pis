[Unit]
Description=Pi1 Timelapse Camera Capture
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/2pis/pi1
ExecStart=/usr/bin/python3 /home/pi/2pis/pi1/camera.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
# Give the network time to fully come up before starting
ExecStartPre=/bin/sleep 5

[Install]
WantedBy=multi-user.target
